# ============================
# 감자마켓 트렌드 대시보드 설정
# ============================
# 이 파일을 복사해서 .env 로 저장 후 값을 채워주세요

# --- 네이버 개발자 센터 ---
# https://developers.naver.com → 애플리케이션 등록 → DataLab 검색 권한 추가
NAVER_CLIENT_ID=여기에_클라이언트_아이디
NAVER_CLIENT_SECRET=여기에_클라이언트_시크릿

# --- Google Sheets ---
# Google Apps Script 웹 앱 배포 URL (setup.md 참조)
GOOGLE_SHEETS_WEBHOOK=여기에_앱스크립트_웹앱_URL

# --- 타오바오커(淘宝客) API ---
# https://open.taobao.com 앱 생성 + 알리마마 타오바오커 권한 + PID(adzone)
TAOBAO_APP_KEY=여기에_타오바오_앱키
TAOBAO_APP_SECRET=여기에_타오바오_앱시크릿
TAOBAO_ADZONE_ID=여기에_광고위치_adzone_id

# --- 서버 설정 ---
PORT=3000

# --- 자동 새로고침 스케줄 (cron 형식) ---
# 기본값: 매일 오전 7시 30분
CRON_SCHEDULE=30 7 * * *
